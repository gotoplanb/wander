__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.DS_Store
*.sqlite
*.sqlite-journal
# Seeded example episodes are content, not transient state — track them.
!episodes/*/episode.sqlite
wanderer-session.json
.env
# Local bench results — runs are per-machine and rebuildable from Conduct.
bench/runs/
# DPO pipeline outputs — per-machine, rebuildable from Conduct's export.
# Keep the dirs themselves (.gitkeep) so the scripts have somewhere to write.
bench/dpo/datasets/*
!bench/dpo/datasets/.gitkeep
bench/dpo/checkpoints/*
!bench/dpo/checkpoints/.gitkeep
