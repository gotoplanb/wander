# Conduct HTTP endpoint + client API key for the bench runner.
#
# CONDUCT_BASE_URL — root URL of the Conduct API (e.g. https://conduct.example.com
# or http://localhost:8000 for the local docker-compose stack).
#
# CONDUCT_TOKEN — a *client* API key minted by Conduct's `make seed`,
# `POST /clients`, or the Clients UI. Format: `cdt_<random>`. Do NOT use
# the admin key here — the bench should look like every other client.
# See conduct/docs/auth.md.
#
# Copy this file to `.env` and fill in. `.env` is gitignored.

CONDUCT_BASE_URL=
CONDUCT_TOKEN=

# DPO pipeline (bench/dpo/) — only needed for the fine-tune loop (wander#7).
#
# CONDUCT_ADMIN_TOKEN — admin key for the /datasets/preferences export.
# Distinct from CONDUCT_TOKEN: the export is a bulk data pull across all
# clients of the tenant, so Conduct requires admin auth. See
# conduct/docs/auth.md and conduct/docs/datasets.md.
#
# WANDER_DPO_BASE_MODEL — HuggingFace/MLX repo id of the base model to
# fine-tune (e.g. mlx-community/gemma-3-4b-it-bf16). Should match the model
# Conduct's routing rule pins as `gemma4:e4b`.
#
# OLLAMA_SSH_HOST — ssh target for the separate Mac that runs the Ollama
# daemon. The DPO push stage scp's the GGUF there and runs `ollama create`
# remotely. This machine never starts Ollama.
#
# OLLAMA_REMOTE_DIR — directory on the Ollama host for checkpoint artifacts
# (default: ~/wander-checkpoints).
#
# LLAMA_CPP_DIR — path to a local clone of github.com/ggerganov/llama.cpp,
# used by the fuse stage's `convert_hf_to_gguf.py`.

CONDUCT_ADMIN_TOKEN=
WANDER_DPO_BASE_MODEL=
OLLAMA_SSH_HOST=
OLLAMA_REMOTE_DIR=
LLAMA_CPP_DIR=
