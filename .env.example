# Conduct HTTP endpoint + client API key for the bench runner.
#
# CONDUCT_BASE_URL — root URL of the Conduct API (e.g. https://conduct.example.com
# or http://localhost:8000 for the local docker-compose stack).
#
# CONDUCT_TOKEN — a *client* API key minted by Conduct's `make seed`,
# `POST /clients`, or the Clients UI. Format: `cdt_<random>`. Do NOT use
# the admin key here — the bench should look like every other client.
# See conduct/docs/auth.md.
#
# Copy this file to `.env` and fill in. `.env` is gitignored.

CONDUCT_BASE_URL=
CONDUCT_TOKEN=
